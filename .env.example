# Copy to .env and fill in your key. .env is gitignored — never commit it.
#
# Get the key from Intervals.icu > Settings > Developer Settings.
INTERVALS_API_KEY=your_key

# Optional. Athlete id "0" (the default) resolves to the key owner, so this
# is only needed if you are querying a different athlete than the key belongs to.
# INTERVALS_ATHLETE_ID=0
